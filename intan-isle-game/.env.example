# NurAIN Backend — Local Development Defaults
DATABASE_URL=postgresql+asyncpg://nurain:nurain_local@localhost:5432/nurain_db
REDIS_URL=redis://localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

JWT_SECRET_KEY=local-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

GAME_BRIDGE_STUB_MODE=true

APP_NAME=NurAIN-MVP
APP_ENV=development
LOG_LEVEL=INFO
